<?xml version="1.0" encoding="utf-8"?>
<!-- Credential Provider Configuration for Passkey Support (Android 14+) -->
<credential-provider
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:settingsSubtitle="@string/passkey_settings_system_subtitle"
    android:settingsActivity="takagi.ru.monica.passkey.PasskeySettingsActivity"
    tools:targetApi="34">
    <capabilities>
        <!-- Password credential type for autofill integration -->
        <capability name="android.credentials.TYPE_PASSWORD_CREDENTIAL" />
        <!--
            Passkey/WebAuthn credential type.

            Google 官方 Credential Provider 文档列出的唯一常量是
            `androidx.credentials.TYPE_PUBLIC_KEY_CREDENTIAL`（即 androidx.credentials
            包里 PublicKeyCredential.TYPE_PUBLIC_KEY_CREDENTIAL 的常量值）。Bitwarden、
            1Password、AOSP 示例工程都只声明这一行。

            另外那行 `android.credentials.TYPE_PUBLIC_KEY_CREDENTIAL`（不带 androidx 前缀）
            在 AOSP / AndroidX 公开 API 里查不到对应常量。但很多老版本 Android 14 设备和
            非 Pixel 的厂商 ROM（Samsung、Xiaomi、OPPO 早期 ROM）的 Credential Manager
            实现会同时识别这两种字符串；曾经把它删掉之后，部分用户的 passkey 直接消失，
            所以保留这行作为兼容性占位 —— 在严格遵守 AOSP 规范的设备上它会被忽略，
            在认这个旧名字的设备上它能避免 passkey 不可用。
        -->
        <capability name="android.credentials.TYPE_PUBLIC_KEY_CREDENTIAL" />
        <capability name="androidx.credentials.TYPE_PUBLIC_KEY_CREDENTIAL" />
    </capabilities>
</credential-provider>
