<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/steam_recent_games_widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/steam_widget_surface"
    android:clickable="true"
    android:focusable="true"
    android:orientation="vertical"
    android:paddingHorizontal="12dp"
    android:paddingVertical="8dp">

    <TextView
        android:id="@+id/steam_recent_games_account"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="@string/steam_widget_recent_games"
        android:textColor="@color/steam_widget_on_surface_variant"
        android:textSize="11sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/steam_recent_games_empty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="@string/steam_widget_no_recent_games"
        android:textColor="@color/steam_widget_on_surface_variant"
        android:textSize="13sp"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/steam_recent_game_row_one"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="5dp"
        android:layout_weight="1"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView android:id="@+id/steam_recent_game_image_one" android:layout_width="72dp" android:layout_height="match_parent" android:background="@drawable/steam_widget_image_surface" android:contentDescription="@null" android:importantForAccessibility="no" android:scaleType="centerCrop" android:src="@mipmap/ic_launcher" />
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="10dp" android:layout_weight="1" android:orientation="vertical">
            <TextView android:id="@+id/steam_recent_game_name_one" android:layout_width="match_parent" android:layout_height="wrap_content" android:ellipsize="end" android:maxLines="1" android:text="Steam" android:textColor="@color/steam_widget_on_surface" android:textSize="15sp" android:textStyle="bold" />
            <TextView android:id="@+id/steam_recent_game_time_one" android:layout_width="match_parent" android:layout_height="wrap_content" android:ellipsize="end" android:maxLines="1" android:text="0 h" android:textColor="@color/steam_widget_on_surface_variant" android:textSize="12sp" />
        </LinearLayout>
        <TextView android:id="@+id/steam_recent_game_state_one" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="4dp" android:textColor="@color/steam_widget_live" android:textSize="14sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/steam_recent_game_row_two"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="6dp"
        android:layout_weight="1"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:visibility="gone">

        <ImageView android:id="@+id/steam_recent_game_image_two" android:layout_width="72dp" android:layout_height="match_parent" android:background="@drawable/steam_widget_image_surface" android:contentDescription="@null" android:importantForAccessibility="no" android:scaleType="centerCrop" android:src="@mipmap/ic_launcher" />
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="10dp" android:layout_weight="1" android:orientation="vertical">
            <TextView android:id="@+id/steam_recent_game_name_two" android:layout_width="match_parent" android:layout_height="wrap_content" android:ellipsize="end" android:maxLines="1" android:text="Steam" android:textColor="@color/steam_widget_on_surface" android:textSize="15sp" android:textStyle="bold" />
            <TextView android:id="@+id/steam_recent_game_time_two" android:layout_width="match_parent" android:layout_height="wrap_content" android:ellipsize="end" android:maxLines="1" android:text="0 h" android:textColor="@color/steam_widget_on_surface_variant" android:textSize="12sp" />
        </LinearLayout>
        <TextView android:id="@+id/steam_recent_game_state_two" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="4dp" android:textColor="@color/steam_widget_live" android:textSize="14sp" />
    </LinearLayout>
</LinearLayout>
