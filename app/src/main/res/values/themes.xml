<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.Monica" parent="android:Theme.Material.Light.NoActionBar">
        <!-- 启动预览窗口与 Material 3 日间背景保持一致 -->
        <item name="android:windowBackground">@color/monica_startup_background</item>
        <item name="android:statusBarColor">@color/monica_startup_background</item>
        <item name="android:navigationBarColor">@color/monica_startup_background</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="android:enforceStatusBarContrast">false</item>
        <item name="android:enforceNavigationBarContrast">false</item>
    </style>
    
    <!-- 透明Activity主题,用于半屏BottomSheet -->
    <style name="Theme.Transparent" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowIsFloating">false</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:backgroundDimAmount">0.5</item>
    </style>
    
    <!-- Legacy non-Steam activities keep their resource IDs for compilation. -->
    <style name="Theme.TransparentDialog" parent="android:Theme.Material.Light.Dialog">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:backgroundDimAmount">0.5</item>
    </style>

    <style name="Theme.ImeBiometricAuth" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowIsTranslucent">false</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowIsFloating">false</item>
        <item name="android:backgroundDimEnabled">false</item>
        <item name="android:windowAnimationStyle">@null</item>
    </style>

    <style name="Theme.Monica.AutofillCallback" parent="Theme.Monica">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowIsFloating">false</item>
        <item name="android:backgroundDimEnabled">false</item>
        <item name="android:windowDisablePreview">true</item>
        <item name="android:windowAnimationStyle">@null</item>
    </style>
    
    <!-- Bottom Sheet主题,用于AutofillPicker -->
    <style name="Theme.Monica.BottomSheet" parent="Theme.Monica">
        <item name="android:windowIsFloating">false</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:backgroundDimAmount">0.5</item>
    </style>
    
    <style name="Theme.Monica.Passkey" parent="Theme.Monica">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsFloating">false</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:backgroundDimAmount">0.6</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <style name="ThemeOverlay.Monica.AutofillAuth" parent="Theme.Monica">
        <item name="android:windowAnimationStyle">@style/Animation.Monica.Dialog.FadeUp</item>
    </style>

    <style name="ShapeAppearance.Monica.AutofillDialog" parent="" />

    <style name="TextAppearance.Monica.AutofillDialog.Title" parent="@android:style/TextAppearance">
        <item name="android:textColor">@color/autofill_auth_dialog_on_surface</item>
    </style>

    <style name="TextAppearance.Monica.AutofillDialog.Body" parent="@android:style/TextAppearance">
        <item name="android:textColor">@color/autofill_auth_dialog_on_surface</item>
    </style>

    <style name="Animation.Monica.Dialog.FadeUp" parent="@style/Animation.AppCompat.Dialog">
        <item name="android:windowEnterAnimation">@android:anim/fade_in</item>
        <item name="android:windowExitAnimation">@android:anim/fade_out</item>
    </style>
</resources>
